<Window x:Class="FloatingClock.WPF.Views.MessageView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FloatingClock.WPF.Views"
        xmlns:viewmodels="clr-namespace:FloatingClock.WPF.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:MessageViewModel}"
        mc:Ignorable="d"
        Title="{Binding Caption}" d:Title="Message Caption" Height="250" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--This is a simple message box, no input, just a message to the user with 'OK'-->
        <Grid Grid.Row="0" Visibility="{Binding IsSimpleMessageVisible}" d:Visibility="Collapsed"
              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,30,10,0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Caption}" d:Text="Message Caption" Margin="0,5" FontWeight="Bold"/>
            <TextBlock Text="{Binding Message}" Grid.Row="1" TextWrapping="Wrap"
                       d:Text="This is the message the user will see. And this text helps to test if this will wrap or simply overflow." />
        </Grid>

        <Grid Grid.Row="0" Visibility="{Binding IsInputMessageVisible}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,5,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Caption}" Margin="0,5" FontWeight="Bold" d:Text="Message Caption"/>
            <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" 
                       d:Text="This is the message the user will see. And this text helps to test if this will wrap or simply overflow."/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="2,15,2,5" HorizontalAlignment="Center">
                <Label Content="Hours: " FontWeight="Bold"/>
                <ComboBox x:Name="cmbHours" MaxWidth="60" Margin="2" ItemsSource="{Binding NumbersList}" ItemStringFormat="{}{0:D2}" SelectedItem="{Binding SelectedHour}"/>
                <Label Content="Minutes: " FontWeight="Bold"/>
                <ComboBox x:Name="cmbMinutes" MaxWidth="60" Margin="2" ItemsSource="{Binding NumbersList}" ItemStringFormat="{}{0:D2}" SelectedItem="{Binding SelectedMinute}"/>
                <Label Content="Seconds: " FontWeight="Bold"/>
                <ComboBox x:Name="cmbSeconds" MaxWidth="60" Margin="2" ItemsSource="{Binding NumbersList}" ItemStringFormat="{}{0:D2}" SelectedItem="{Binding SelectedSeconds}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="btnOK" Content="OK" Margin="2,0" Padding="5" MinWidth="50" Command="{Binding OnOKCommand}"/>
            <Button x:Name="btnCancel" Content="Cancel" Margin="2,0,0,0" Padding="5" MinWidth="50" Visibility="Collapsed" Command="{Binding OnCancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
